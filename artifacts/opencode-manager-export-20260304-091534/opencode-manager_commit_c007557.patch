From c0075579c2955b7f784f501d1720fce0112b856f Mon Sep 17 00:00:00 2001
From: Ubuntu <ubuntu@ip-172-26-6-168.ap-northeast-2.compute.internal>
Date: Wed, 4 Mar 2026 09:06:23 +0000
Subject: [PATCH] chore(compose): update workspace mounts and add backup
 compose snapshot

---
 docker-compose.yml                     |  8 ++--
 docker-compose.yml.bak.20260303-001326 | 60 ++++++++++++++++++++++++++
 2 files changed, 64 insertions(+), 4 deletions(-)
 create mode 100644 docker-compose.yml.bak.20260303-001326

diff --git a/docker-compose.yml b/docker-compose.yml
index 88f4caf..a3deaca 100644
--- a/docker-compose.yml
+++ b/docker-compose.yml
@@ -16,7 +16,7 @@ services:
       - PORT=5003
       - OPENCODE_SERVER_PORT=5551
       - DATABASE_PATH=/app/data/opencode.db
-      - WORKSPACE_PATH=/workspace
+      - WORKSPACE_PATH=/home/ubuntu
       - PROCESS_START_WAIT_MS=2000
       - PROCESS_VERIFY_WAIT_MS=1000
       - HEALTH_CHECK_INTERVAL_MS=5000
@@ -43,7 +43,9 @@ services:
       - VAPID_PRIVATE_KEY=${VAPID_PRIVATE_KEY:-}
       - VAPID_SUBJECT=${VAPID_SUBJECT:-}
     volumes:
-      - opencode-workspace:/workspace
+      - /home/ubuntu:/home/ubuntu
+      - /home/ubuntu/.config/opencode:/home/ubuntu/.config/opencode
+      - /home/ubuntu/.opencode:/home/ubuntu/.opencode
       - opencode-data:/app/data
     restart: unless-stopped
     healthcheck:
@@ -54,7 +56,5 @@ services:
       start_period: 40s
 
 volumes:
-  opencode-workspace:
-    driver: local
   opencode-data:
     driver: local
diff --git a/docker-compose.yml.bak.20260303-001326 b/docker-compose.yml.bak.20260303-001326
new file mode 100644
index 0000000..88f4caf
--- /dev/null
+++ b/docker-compose.yml.bak.20260303-001326
@@ -0,0 +1,60 @@
+services:
+  app:
+    build:
+      context: .
+      dockerfile: Dockerfile
+    container_name: opencode-manager
+    ports:
+      - "5003:5003"
+      - "5100:5100"
+      - "5101:5101"
+      - "5102:5102"
+      - "5103:5103"
+    environment:
+      - NODE_ENV=${NODE_ENV:-production}
+      - HOST=0.0.0.0
+      - PORT=5003
+      - OPENCODE_SERVER_PORT=5551
+      - DATABASE_PATH=/app/data/opencode.db
+      - WORKSPACE_PATH=/workspace
+      - PROCESS_START_WAIT_MS=2000
+      - PROCESS_VERIFY_WAIT_MS=1000
+      - HEALTH_CHECK_INTERVAL_MS=5000
+      - HEALTH_CHECK_TIMEOUT_MS=30000
+      - MAX_FILE_SIZE_MB=50
+      - MAX_UPLOAD_SIZE_MB=50
+      - DEBUG=false
+      - AUTH_SECRET=${AUTH_SECRET}
+      - AUTH_TRUSTED_ORIGINS=${AUTH_TRUSTED_ORIGINS:-http://localhost:5003}
+      - ADMIN_EMAIL=${ADMIN_EMAIL:-}
+      - ADMIN_PASSWORD=${ADMIN_PASSWORD:-}
+      - ADMIN_PASSWORD_RESET=${ADMIN_PASSWORD_RESET:-false}
+      - GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID:-}
+      - GITHUB_CLIENT_SECRET=${GITHUB_CLIENT_SECRET:-}
+      - GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID:-}
+      - GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET:-}
+      - DISCORD_CLIENT_ID=${DISCORD_CLIENT_ID:-}
+      - DISCORD_CLIENT_SECRET=${DISCORD_CLIENT_SECRET:-}
+      - AUTH_SECURE_COOKIES=${AUTH_SECURE_COOKIES:-false}
+      - PASSKEY_RP_ID=${PASSKEY_RP_ID:-localhost}
+      - PASSKEY_RP_NAME=${PASSKEY_RP_NAME:-OpenCode Manager}
+      - PASSKEY_ORIGIN=${PASSKEY_ORIGIN:-http://localhost:5003}
+      - VAPID_PUBLIC_KEY=${VAPID_PUBLIC_KEY:-}
+      - VAPID_PRIVATE_KEY=${VAPID_PRIVATE_KEY:-}
+      - VAPID_SUBJECT=${VAPID_SUBJECT:-}
+    volumes:
+      - opencode-workspace:/workspace
+      - opencode-data:/app/data
+    restart: unless-stopped
+    healthcheck:
+      test: ["CMD", "curl", "-f", "http://localhost:5003/api/health"]
+      interval: 30s
+      timeout: 3s
+      retries: 3
+      start_period: 40s
+
+volumes:
+  opencode-workspace:
+    driver: local
+  opencode-data:
+    driver: local
-- 
2.43.0

